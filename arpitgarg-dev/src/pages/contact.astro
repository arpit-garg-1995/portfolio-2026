---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Arpit Garg"
  description="Get in touch with Arpit Garg for iOS, Swift, camera systems, and collaboration."
  path="/contact/"
>
  <section class="section">
    <div class="grid grid-2">
      <div class="card">
        <h1>Contact</h1>
        <p>If you want to discuss iOS roles, camera-heavy app work, architecture consulting, or collaboration, send a message here.</p>
        <div class="pill-row">
          <a class="pill" href="mailto:arpit@example.com">arpit@example.com</a>
          <a class="pill" href="https://github.com/your-github" target="_blank" rel="noreferrer">GitHub</a>
          <a class="pill" href="https://www.linkedin.com/in/your-linkedin" target="_blank" rel="noreferrer">LinkedIn</a>
        </div>
      </div>

      <div class="card">
        <!-- Web3Forms: free, no backend, works on Cloudflare Pages -->
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          id="contact-form"
        >
          <!-- Replace YOUR_ACCESS_KEY with the key from web3forms.com -->
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY" />
          <!-- Optional: redirect after submission -->
          <input type="hidden" name="redirect" value="https://arpitgarg.pages.dev/contact/?sent=true" />
          <!-- Honeypot for spam prevention -->
          <input type="checkbox" name="botcheck" style="display:none" />

          <label>
            <span class="small">Name</span>
            <input type="text" name="name" required />
          </label>

          <label>
            <span class="small">Email</span>
            <input type="email" name="email" required />
          </label>

          <label>
            <span class="small">Message</span>
            <textarea name="message" required></textarea>
          </label>

          <button class="btn btn-primary" type="submit">Send Message</button>
        </form>

        <!-- Thank-you message shown after redirect back with ?sent=true -->
        <div id="form-success" style="display:none;" class="pill">
          Message sent! I'll reply within 48 hours.
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    if (new URLSearchParams(window.location.search).get('sent') === 'true') {
      document.getElementById('contact-form').style.display = 'none';
      document.getElementById('form-success').style.display = 'block';
    }
  </script>
</BaseLayout>
