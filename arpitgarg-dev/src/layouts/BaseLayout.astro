---
const {
  title = 'Arpit Garg | Senior iOS Engineer',
  description = 'Senior iOS Engineer building camera-heavy apps, Swift systems, blogs, and small browser games.',
  path = '/'
} = Astro.props;

const site = Astro.site ?? new URL('https://arpitgarg.netlify.app');
const canonical = new URL(path, site).toString();
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#0b1020" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site}og-card.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Arpit Garg',
      jobTitle: 'Senior iOS Engineer',
      url: String(site),
      sameAs: [
        'https://github.com/your-github',
        'https://www.linkedin.com/in/your-linkedin'
      ],
      knowsAbout: [
        'Swift',
        'iOS',
        'AVCaptureMultiCamSession',
        'Video Systems',
        'MVVM',
        'Coordinator',
        'LeetCode'
      ]
    })} />
    <script is:inline>
      const storedTheme = localStorage.getItem('ag-theme');
      const theme = storedTheme || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      document.documentElement.dataset.theme = theme;
    </script>
    <style is:global>
      :root {
        --bg: #0b1020;
        --panel: #121936;
        --panel-2: #182140;
        --text: #eef2ff;
        --muted: #a7b1d6;
        --brand: #73e2a7;
        --brand-2: #76a9ff;
        --border: rgba(255,255,255,.12);
        --shadow: 0 18px 50px rgba(0,0,0,.28);
        --radius: 18px;
        --max: 1100px;
      }

      html[data-theme="light"] {
        --bg: #f6f8fc;
        --panel: #ffffff;
        --panel-2: #eef3ff;
        --text: #111827;
        --muted: #4b5563;
        --brand: #0f9d58;
        --brand-2: #2563eb;
        --border: rgba(17,24,39,.10);
        --shadow: 0 18px 50px rgba(15,23,42,.10);
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top right, rgba(118,169,255,.12), transparent 24%),
          radial-gradient(circle at top left, rgba(115,226,167,.10), transparent 20%),
          var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      a { color: inherit; text-decoration: none; }
      img { max-width: 100%; display: block; }
      .container { width: min(var(--max), calc(100% - 2rem)); margin: 0 auto; }
      .site-header {
        position: sticky; top: 0; z-index: 20;
        backdrop-filter: blur(14px);
        background: color-mix(in oklab, var(--bg) 82%, transparent);
        border-bottom: 1px solid var(--border);
      }

      .nav {
        display: flex; align-items: center; justify-content: space-between;
        gap: 1rem; padding: .95rem 0;
      }

      .brand {
        display: inline-flex; align-items: center; gap: .8rem; font-weight: 700;
      }

      .brand-mark {
        width: 40px; height: 40px; border-radius: 12px;
        display: grid; place-items: center;
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        color: #081019; font-weight: 900;
      }

      .nav-links {
        display: flex; flex-wrap: wrap; gap: .8rem;
        align-items: center;
      }

      .nav-links a, .nav-links button {
        padding: .7rem .95rem; border-radius: 999px; border: 1px solid var(--border);
        background: transparent; color: var(--text); cursor: pointer; font: inherit;
      }

      .hero {
        padding: 4rem 0 2rem;
        display: grid; gap: 1.4rem;
      }

      .hero-grid {
        display: grid; gap: 1.25rem;
        grid-template-columns: 1.25fr .75fr;
      }

      .card, .panel {
        background: linear-gradient(180deg, var(--panel), color-mix(in srgb, var(--panel), #000 5%));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
      }

      .card { padding: 1.25rem; }
      .hero-copy { padding: 1.75rem; }
      .eyebrow {
        display: inline-flex; gap: .5rem; align-items: center;
        border: 1px solid var(--border); border-radius: 999px;
        padding: .35rem .8rem; color: var(--muted); font-size: .92rem;
      }

      h1, h2, h3 { line-height: 1.12; margin: 0 0 .7rem; }
      h1 { font-size: clamp(2.2rem, 5vw, 4.2rem); }
      h2 { font-size: clamp(1.55rem, 2.6vw, 2.2rem); }
      h3 { font-size: 1.15rem; }
      p { margin: 0 0 1rem; color: var(--muted); }
      .accent { color: var(--brand); }

      .cta-row, .pill-row, .meta-row {
        display: flex; flex-wrap: wrap; gap: .75rem;
      }

      .btn {
        display: inline-flex; align-items: center; justify-content: center;
        padding: .9rem 1.1rem; border-radius: 14px; font-weight: 700;
        border: 1px solid var(--border);
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        color: #071019; border: none;
      }

      .btn-secondary { background: var(--panel-2); }

      .hero-side {
        display: grid; gap: 1rem;
      }

      .avatar {
        aspect-ratio: 1 / 1; overflow: hidden;
        border-radius: var(--radius);
        border: 1px solid var(--border);
      }

      .section {
        padding: 1.5rem 0 2.5rem;
      }

      .grid {
        display: grid; gap: 1rem;
      }

      .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }

      .pill {
        border: 1px solid var(--border);
        background: var(--panel-2);
        padding: .55rem .8rem;
        border-radius: 999px;
        color: var(--text);
        font-size: .95rem;
      }

      .post-list a, .project-card, .mini-card {
        display: block;
        padding: 1.15rem;
        border: 1px solid var(--border);
        border-radius: 16px;
        background: var(--panel);
        transition: transform .18s ease, border-color .18s ease;
      }

      .post-list a:hover, .project-card:hover, .mini-card:hover {
        transform: translateY(-2px);
        border-color: color-mix(in srgb, var(--brand) 35%, var(--border));
      }

      .mono {
        font-family: "Roboto Mono", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }

      .stats {
        display: grid; grid-template-columns: repeat(3, 1fr); gap: .75rem;
      }

      .stat {
        background: var(--panel-2);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: .9rem;
        text-align: center;
      }

      .boards {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
      }

      .board {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .5rem;
      }

      .cell, .dash-cell {
        min-height: 74px;
        border-radius: 16px;
        border: 1px solid var(--border);
        background: var(--panel-2);
        color: var(--text);
        font-size: 1.6rem;
        font-weight: 800;
        cursor: pointer;
      }

      .cell[disabled], .dash-cell[disabled] {
        opacity: .75;
        cursor: not-allowed;
      }

      .game-header, .game-actions {
        display: flex; gap: .75rem; justify-content: space-between; align-items: center;
        flex-wrap: wrap;
      }

      .game-note {
        font-size: .94rem;
        color: var(--muted);
      }

      .dash-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: .6rem;
        margin-top: 1rem;
      }

      .dash-cell.active {
        background: linear-gradient(135deg, var(--brand), var(--brand-2));
        color: #06111d;
      }

      form {
        display: grid; gap: .9rem;
      }

      input, textarea {
        width: 100%;
        border-radius: 14px;
        border: 1px solid var(--border);
        background: var(--panel-2);
        color: var(--text);
        padding: .95rem 1rem;
        font: inherit;
      }

      textarea { min-height: 150px; resize: vertical; }

      .footer {
        padding: 2rem 0 3rem;
        color: var(--muted);
      }

      .small { font-size: .92rem; color: var(--muted); }

      @media (max-width: 860px) {
        .hero-grid, .grid-2, .grid-3, .boards { grid-template-columns: 1fr; }
        .nav { align-items: flex-start; flex-direction: column; }
      }

      @media (prefers-reduced-motion: reduce) {
        html { scroll-behavior: auto; }
        * { transition: none !important; animation: none !important; }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">
          <span class="brand-mark">AG</span>
          <span>Arpit Garg</span>
        </a>

        <nav class="nav-links" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/blog/">Blog</a>
          <a href="/projects/">Projects</a>
          <a href="/games/">Games</a>
          <a href="/contact/">Contact</a>
          <button id="theme-toggle" type="button" aria-label="Toggle theme">Theme</button>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="container footer">
      <div class="card">
        <p><strong>Arpit Garg</strong> — Senior iOS Engineer, camera/video specialist, and builder of fast developer tools.</p>
        <p class="small">© {year} Arpit Garg. Built with Astro, shipped as a static site.</p>
      </div>
    </footer>

    <script is:inline>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        localStorage.setItem('ag-theme', next);
      });

      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => navigator.serviceWorker.register('/sw.js'));
      }
    </script>
  </body>
</html>
